# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Found in: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Direct database connection URL (used by Python scripts)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# Anthropic (Claude API — used for weekly AI summarization)
ANTHROPIC_API_KEY=

# Voyage AI (embeddings — used for address matching)
VOYAGE_API_KEY=

# Lob (USPS postcards)
LOB_API_KEY=
# Pre-create a sender address in your Lob account dashboard and paste the ID here
# e.g. adr_xxxxxxxxxxxxxxxx
LOB_FROM_ADDRESS_ID=

# Iowa voter file path (local only — never commit the real file)
VOTER_FILE_PATH=./data/iowa_voter_file.csv

# Geocoding (no API keys needed — Census API and Nominatim are free)
GEOCODING_BATCH_SIZE=100
GEOCODING_DELAY_MS=200
